generator client {
  provider = "prisma-client-js"
}

// 1. 将数据源修改为 PostgreSQL，并配置 Vercel 专用的双链接（连接池 + 直连）
datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")     // 用于日常查询（带连接池，防止 Serverless 连接数爆满）
  directUrl = env("POSTGRES_URL_NON_POOLING") // 用于数据库结构迁移（直连）
}

model Vehicle {
  id        Int          @id @default(autoincrement())
  plateNo   String       @unique
  type      String       // 例如: 挖掘机, 叉车, 货车
  createdAt DateTime     @default(now())
  records   FuelRecord[]
}

model FuelRecord {
  id        Int      @id @default(autoincrement())
  vehicleId Int
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  amount    Float    // 加油量(升)
  mileage   Float    // 里程数或工作小时数
  date      DateTime @default(now())
}

model Inventory {
  id        Int      @id @default(autoincrement())
  total     Float    @default(0) // 总库存
  updatedAt DateTime @updatedAt
}

model InventoryTransaction {
  id        Int      @id @default(autoincrement())
  type      String   // IN (入库) 或 OUT (出库)
  amount    Float
  date      DateTime @default(now())
  note      String?
}
